# ============================================================
# LexOS — Exemplo de Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA coloque senhas reais neste arquivo!
# ============================================================

# ----------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# ----------------------------------------------------------
POSTGRES_PASSWORD=

# ----------------------------------------------------------
# CACHE / FILAS — Redis
# ----------------------------------------------------------
REDIS_PASSWORD=

# ----------------------------------------------------------
# API PRINCIPAL — Go
# Gere com: openssl rand -base64 32
# ----------------------------------------------------------
JWT_SECRET=

API_URL=http://localhost:8080
APP_URL=http://localhost:3000

# ----------------------------------------------------------
# FRONTEND — Next.js
# Gere com: openssl rand -base64 32
# ----------------------------------------------------------
NEXTAUTH_SECRET=

# ----------------------------------------------------------
# SERVIÇO DE IA — Python
# ----------------------------------------------------------
OPENAI_API_KEY=

# ----------------------------------------------------------
# INTEGRAÇÃO CNJ — Java
# ----------------------------------------------------------
CNJ_API_KEY=

# ----------------------------------------------------------
# MONITORAMENTO — Grafana
# ----------------------------------------------------------
GRAFANA_PASSWORD=
